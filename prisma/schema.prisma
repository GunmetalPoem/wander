generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model TripRoom {
  id                String   @id @default(cuid())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  expiresAt         DateTime
  unifiedDraftJson  String
  planJson          String?
  planWeatherJson   String?
  planBuiltAt       DateTime?
  planBuildLockAt   DateTime?
  planBuildLockBy   String?

  participants RoomParticipant[]
  messages     RoomMessage[]
  preferences  ParticipantPreferences[]
}

model RoomParticipant {
  id          String   @id @default(cuid())
  roomId      String
  cookieId    String
  displayName String
  colorHex    String
  joinedAt    DateTime @default(now())
  lastSeenAt  DateTime @default(now())

  room        TripRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, cookieId])
  @@index([roomId])
}

model RoomMessage {
  id              String    @id @default(cuid())
  roomId          String
  participantId   String?
  role            String
  content         String
  createdAt       DateTime  @default(now())
  aiProcessingAt  DateTime?
  aiProcessedAt   DateTime?

  room            TripRoom  @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, createdAt])
  @@index([roomId, aiProcessedAt])
}

model ParticipantPreferences {
  id            String   @id @default(cuid())
  roomId        String
  participantId String   @unique
  prefsJson     String
  updatedAt     DateTime @updatedAt

  room          TripRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
}
