{
  "name": "wander",
  "version": "0.1.0",
  "private": true,
  "description": "Wander — AI trip planner with Mapbox and routing.",
  "scripts": {
    "clean": "rm -rf .next",
    "dev": "next dev",
    "dev:turbo": "node -e \"console.error('\\n[Wander] Trip planner uses mapbox-gl; Turbopack often hits module-not-found on /. Use: npm run dev (no --turbo).\\n')\" && next dev --turbo",
    "dev:poll": "WATCHPACK_POLLING=true next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "eval": "node tools/eval/route-optimizer-eval.ts",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/client": "^6.6.0",
    "cheerio": "^1.0.0",
    "fastest-levenshtein": "^1.0.16",
    "framer-motion": "^11.18.2",
    "lucide-react": "^1.17.0",
    "mapbox-gl": "^3.22.0",
    "next": "^15.5.15",
    "openai": "^4.96.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-map-gl": "^8.1.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/mapbox-gl": "^3.4.0",
    "@types/node": "^20.17.30",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.6",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.15",
    "postcss": "^8.5.3",
    "prisma": "^6.6.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3"
  }
}
