# SQLite database (default path works with prisma/schema.prisma)
DATABASE_URL="file:./dev.db"

# Required for /admin scrape → AI categorization
OPENAI_API_KEY="sk-..."

# Optional: use official Reddit API (more reliable than public .json endpoints)
# Create an app at https://www.reddit.com/prefs/apps (type: "script" is fine for this server-side use)
REDDIT_CLIENT_ID=""
REDDIT_CLIENT_SECRET=""

# Optional: MontFerret CLI (https://github.com/MontFerret/cli) for better HTML extraction
# Install: e.g. go install github.com/MontFerret/cli/v2/ferret@latest
# LORE_USE_FERRET=1 / LORE_FERRET_CDP=1 use headless Chrome for JS-heavy pages (slower)
LORE_USE_FERRET="0"
LORE_FERRET_CDP="0"
FERRET_PATH="ferret"
LORE_FERRET_TIMEOUT_MS="120000"

# Optional: Scrapy (https://github.com/scrapy/scrapy) — `python3 -m pip install -r tools/scrapy-fetch/requirements.txt`
# Uses Twisted/Scrapy downloads instead of plain node fetch (better redirects/retries). Falls back to fetch if Python fails.
# LORE_USE_SCRAPY=1
# LORE_SCRAPY_SCRIPT=  # default: <repo>/tools/scrapy-fetch/fetch_one.py
# LORE_PYTHON=python3  # or full path; on Windows the default is `py -3` if unset

# Optional: quest compile (see README) — second model pass + optional curation draft if strict pass is empty
# LORE_SKIP_QUEST_RECOVERY=1   # only one model pass; no relaxed pass or stub
# LORE_NO_QUEST_STUB=1         # no auto curation draft (relaxed pass still runs when corpus is large)
# LORE_NO_QUEST_REPAIR_TURN=1  # if first model response is hollow, do not run a second “repair” API call

# Optional: require this header on POST /api/scrape and POST /api/quests/publish
# Example: curl -H "x-admin-secret: your-secret" ...
ADMIN_SECRET=""

# --- Wanderday trip planner (/) ---
# Default public token from https://account.mapbox.com/ (pk.…); works for the 3D map in the browser
# and for Directions/Geocoding in API routes. Optional: MAPBOX_ACCESS_TOKEN for server-only (falls back to NEXT_PUBLIC).
NEXT_PUBLIC_MAPBOX_TOKEN=""
# MAPBOX_ACCESS_TOKEN=""

# Optional: Google — primary place resolution (Places Text Search + Find Place). Enable in Google Cloud:
# Places API (legacy) and Geocoding API (for city center when Mapbox is unset). Same key can be used.
# GOOGLE_PLACES_API_KEY=""
# GOOGLE_MAPS_API_KEY=""   # alias; either name is read

# Itinerary AI: prefer Anthropic (same format as /api/trip/plan)
ANTHROPIC_API_KEY=""
# ANTHROPIC_MODEL="claude-3-5-sonnet-20241022"
# If ANTHROPIC_API_KEY is unset, OpenAI is used when OPENAI_API_KEY is set.
