# SQLite database (default path works with prisma/schema.prisma) — optional if you use prisma seed
DATABASE_URL="file:./dev.db"

# Trip planner + stop-details AI (required for trip unless using demo only)
OPENAI_API_KEY="sk-..."

# Optional: MontFerret CLI (https://github.com/MontFerret/cli) — used when fetching pages for stop details
# LORE_USE_FERRET=1 / LORE_FERRET_CDP=1 use headless Chrome for JS-heavy pages (slower)
LORE_USE_FERRET="0"
LORE_FERRET_CDP="0"
FERRET_PATH="ferret"
LORE_FERRET_TIMEOUT_MS="120000"

# Optional: Scrapy (https://github.com/scrapy/scrapy) — `python3 -m pip install -r tools/scrapy-fetch/requirements.txt`
# LORE_USE_SCRAPY=1
# LORE_SCRAPY_SCRIPT=  # default: <repo>/tools/scrapy-fetch/fetch_one.py
# LORE_PYTHON=python3

# --- Wanderday trip planner (/) ---
NEXT_PUBLIC_MAPBOX_TOKEN=""
# MAPBOX_ACCESS_TOKEN=""

# Optional: Google — Places Text Search + Find Place / Geocoding
# GOOGLE_PLACES_API_KEY=""
# GOOGLE_MAPS_API_KEY=""

ANTHROPIC_API_KEY=""
# ANTHROPIC_MODEL="claude-3-5-sonnet-20241022"
# If ANTHROPIC_API_KEY is unset, OpenAI is used when OPENAI_API_KEY is set.
# OPENAI_MODEL="gpt-5.4"
